{
	"name": "@ltgc/seamstress",
	"version": "0.0.10",
	"license": "LGPL-3.0-only",
	"exports": {
		".": "./dist/seamstress.d.mts"
	},
	"imports": {
		"@ltgc/rochelle": "jsr:@ltgc/rochelle@^0.3.0"
	},
	"dependencies": {
		"jsr:@ltgc/rochelle": "^0.3.0"
	},
	"publish": {
		"include": [
			"dist/**",
			"README.md"
		]
	},
	"fmt": {
		"useTabs": true,
		"lineWidth": 200,
		"indentWidth": 4,
		"semiColons": true,
		"exclude": [
			"*",
			"**/*"
		]
	},
	"lint": {
		"exclude": [
			"*"
		],
		"rules": {
			"tags": [],
			"include": [
				"constructor-super",
				"getter-return",
				"no-await-in-sync-fn",
				"no-cond-assign",
				"no-constant-condition",
				"no-dupe-args",
				"no-dupe-class-members",
				"no-dupe-else-if",
				"no-dupe-keys",
				"no-duplicate-case",
				"no-eval",
				"no-extra-boolean-cast",
				"no-extra-non-null-assertion",
				"no-invalid-regexp",
				"no-irregular-whitespace",
				"no-misused-new",
				"no-new-symbol",
				"no-node-globals",
				"no-non-null-asserted-optional-chain",
				"no-obj-calls",
				"no-process-global",
				"no-redeclare",
				"no-regex-spaces",
				"no-self-assign",
				"no-setter-return",
				"no-shadow-restricted-names",
				"no-sloppy-imports",
				"no-this-before-super",
				"no-throw-literal",
				"no-unused-labels",
				"no-unused-vars",
				"no-with",
				"require-yield",
				"use-isnan",
				"valid-typeof"
			]
		}
	},
	"nodeModulesDir": false,
	"npmRegistry": "http://0.0.0.0:80/"
}
